      <aliases enabled='yes' />
      <column caption='Profit Margin' datatype='real' name='[Calculation_1552251881697280]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[profit] / [sales]' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_1552251882012673]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[sales] - [profit]' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_1552251882110978]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) / COUNTD([order_id])' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_1552251882344451]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag]) / COUNT([order_id])' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='string' name='[Calculation_1552251882713092]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &lt;= 2 THEN &quot;Fast (0-2 Days)&quot;&#13;&#10;ELSEIF [delivery_days] &lt;= 5 THEN &quot;Normal (3-5 Days)&quot;&#13;&#10;ELSEIF [delivery_days] &lt;= 8 THEN &quot;Delayed (6-8 Days)&quot;&#13;&#10;ELSE &quot;Highly Delayed (9+ Days)&quot;&#13;&#10;END' />
      </column>
